        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is success', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Store auth tokens from response', function () {",
                  "  const body = pm.response.json();",
                  "  const token = body?.data?.token || body?.data?.sessionToken || body?.token || '';",
                  "  const access = body?.data?.accessToken || body?.accessToken || '';",
                  "  const refresh = body?.data?.refreshToken || body?.refreshToken || '';",
                  "  if (token) pm.collectionVariables.set('sessionToken', token);",
                  "  if (access) pm.collectionVariables.set('accessToken', access);",
                  "  if (refresh) pm.collectionVariables.set('refreshToken', refresh);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
