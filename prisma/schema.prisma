// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Portfolio Prisma Schema

// ================================
// USER / OWNER
// ================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  phone         String?
  password      String?
  role          Role     @default(OWNER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile  Profile?
  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@map("verifications")
}

enum Role {
  OWNER
  ADMIN
}

// ================================
// PROFILE
// ================================

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  tagline   String? // যেমন: "Full Stack Developer"
  bio       String? @db.Text
  avatarUrl String?
  resumeUrl String?
  location  String?
  website   String?
  available Boolean @default(true) // "Available for work" badge

  // Social Links
  github   String?
  linkedin String?
  twitter  String?
  youtube  String?
  dribbble String?
  behance  String?

  // SEO
  metaTitle       String?
  metaDescription String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ================================
// PROJECTS
// ================================

model Project {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String        @db.Text
  content     String?       @db.Text // Full case study / markdown
  coverImage  String?
  liveUrl     String?
  githubUrl   String?
  featured    Boolean       @default(false)
  status      ProjectStatus @default(PUBLISHED)
  startDate   DateTime?
  endDate     DateTime?
  sortOrder   Int           @default(0)
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?

  tags         ProjectTag[]
  images       ProjectImage[]
  skills       ProjectSkill[]
  testimonials Testimonial[]

  @@map("projects")
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model ProjectImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@map("project_images")
}

// ================================
// CATEGORIES & TAGS
// ================================

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  color       String? // hex color, যেমন "#3B82F6"
  icon        String?

  projects Project[]

  @@map("categories")
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  projects ProjectTag[]
  posts    PostTag[]

  @@map("tags")
}

model ProjectTag {
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  @@id([projectId, tagId])
  @@map("project_tags")
}

// ================================
// SKILLS
// ================================

model Skill {
  id          String     @id @default(cuid())
  name        String
  iconUrl     String?
  proficiency Int        @default(80) // 0–100
  category    SkillGroup
  sortOrder   Int        @default(0)
  featured    Boolean    @default(false)

  projects ProjectSkill[]

  @@map("skills")
}

enum SkillGroup {
  FRONTEND
  BACKEND
  DATABASE
  DEVOPS
  DESIGN
  MOBILE
  OTHER
}

model ProjectSkill {
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId   String

  @@id([projectId, skillId])
  @@map("project_skills")
}

// ================================
// EXPERIENCE
// ================================

model Experience {
  id             String       @id @default(cuid())
  company        String
  role           String
  description    String?      @db.Text
  logoUrl        String?
  companyUrl     String?
  employmentType String?
  locationType   LocationType @default(REMOTE)
  startDate      DateTime
  endDate        DateTime?
  current        Boolean      @default(false)
  sortOrder      Int          @default(0)

  @@map("experiences")
}

enum LocationType {
  REMOTE
  ONSITE
  HYBRID
}

// ================================
// EDUCATION
// ================================

model Education {
  id          String    @id @default(cuid())
  institution String
  degree      String
  field       String?
  logoUrl     String?
  grade       String?
  startDate   DateTime
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?   @db.Text

  @@map("educations")
}

// ================================
// CERTIFICATIONS
// ================================

model Certification {
  id            String    @id @default(cuid())
  name          String
  issuer        String
  issueDate     DateTime
  expiryDate    DateTime?
  credentialId  String?
  credentialUrl String?
  badgeUrl      String?

  @@map("certifications")
}

// ================================
// BLOG (Optional)
// ================================

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?   @db.Text
  content     String    @db.Text
  coverImage  String?
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  readingTime Int? // minutes
  viewCount   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tags PostTag[]

  @@map("posts")
}

model PostTag {
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([postId, tagId])
  @@map("post_tags")
}

// ================================
// TESTIMONIALS
// ================================

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  company   String?
  avatarUrl String?
  content   String   @db.Text
  rating    Int?     @default(5) // 1–5
  featured  Boolean  @default(false)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  @@map("testimonials")
}

// ================================
// CONTACT MESSAGES
// ================================

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String        @db.Text
  status    MessageStatus @default(UNREAD)
  ip        String?
  createdAt DateTime      @default(now())
  readAt    DateTime?
  repliedAt DateTime?

  @@map("contact_messages")
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
  SPAM
}

// ================================
// ANALYTICS (Simple)
// ================================

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  ip        String?
  country   String?
  createdAt DateTime @default(now())

  @@map("page_views")
}
